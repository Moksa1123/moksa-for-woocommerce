{
    "name": "moksaweb/mo-ectools",
    "description": "Moksa for WooCommerce — Taiwan e-commerce toolkit (payments, shipping, invoices).",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "MoksaWeb",
            "homepage": "https://github.com/Moksa1123"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ecpay/sdk": "^1.3"
    },
    "require-dev": {
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpunit/phpunit": "^10.5",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "MoksaWeb\\Mowc\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MoksaWeb\\Mowc\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": [
            "phpcs",
            "bash scripts/check-meta-keys.sh"
        ],
        "lint:fix": "phpcbf",
        "test": "phpunit",
        "check:meta-keys": "bash scripts/check-meta-keys.sh"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "8.2"
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
