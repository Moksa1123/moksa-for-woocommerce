# Build & dependencies
/vendor/
/node_modules/
# Block bundles ship via git (wp.org needs the built JS). Track everything
# under methods/; ignore only the top-level build/ dir's other contents.
# NOTE: a child can't be re-included once its parent dir is excluded, so we
# exclude build/* (direct children only) and re-include the methods/ subtree.
/assets/blocks/build/*
!/assets/blocks/build/methods/
/.phpunit.cache/
/.phpcs-cache

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# Logs
/wp-content/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Composer / NPM lock files: keep them
# (composer.lock and package-lock.json should be committed)

# WP-CLI test artifacts
/tests/tmp/

# Local config
.env
.env.local
phpunit.xml

# Dev-only docs and tooling (kept local, not shipped to wp.org / not in GitHub repo)
/CLAUDE.md
/MEMORY.md
/CHANGELOG.md
/phpcs.xml
/.editorconfig
/scripts/

# Distribution
/dist/
/*.zip

# E2E screenshots (work artifacts, organized in screenshots/)
/screenshots/
/.playwright-mcp/
.wp-org-assets/
